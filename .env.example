# Solana RPC — get a free key from Helius (helius.dev) or Alchemy for better rate limits
VITE_RPC_URL=https://api.mainnet-beta.solana.com

# Treasury wallet — receives platform fees on settlement
VITE_TREASURY_WALLET=GB6CqqrhVj8cZZDpvY1Kh77bvESbypEc4aFUWWFBK16y

# Platform wallet — needs to co-sign settlement transactions (backend required in production)
VITE_PLATFORM_WALLET=GB6CqqrhVj8cZZDpvY1Kh77bvESbypEc4aFUWWFBK16y

# NFT collection mints for fee discount (1.5% instead of 3%)
# Set these to the verified collection mint addresses on mainnet
VITE_BANDO_KIDS_MINT=
VITE_TRAP_STARS_MINT=
